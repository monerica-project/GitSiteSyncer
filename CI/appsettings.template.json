{
  "GitDirectory": "${GIT_DIRECTORY}",
  "LockFileDirectory": "${LOCK_FILE_DIRECTORY}",
  "GitCredentials": {
    "Email": "${GIT_EMAIL}",
    "Username": "${GIT_USERNAME}",
    "Password": "${GIT_PASSWORD}"
  },
  "SitemapUrl": "${SITEMAP_URL}",
  "MinutesToConsider": ${MINUTES_TO_CONSIDER},
  "AppHostDomain": "${APP_HOST_DOMAIN}",
  "NoAppHostDomain": "${NO_APP_HOST_DOMAIN}",
  "Exclusions": [
    "404.html",
    "offline.html"
  ]
}
